<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Detalle de Venta</title>

  <style>
    @import url("https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap");

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: "Poppins", sans-serif;
    }

    body {
      background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
      color: #f1f1f1;
      min-height: 100vh;
      padding: 3rem 1rem;
      display: flex;
      justify-content: center;
    }

    .container {
      width: 100%;
      max-width: 900px;
      background: rgba(255, 255, 255, 0.05);
      padding: 2.5rem;
      border-radius: 15px;
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.06);
      box-shadow: 0 0 25px rgba(179, 136, 255, 0.2);
      animation: fadeIn 0.35s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    h1 {
      text-align: center;
      font-size: 2rem;
      margin-bottom: 0.5rem;
      color: #b388ff;
      text-shadow: 0 0 12px rgba(179, 136, 255, 0.6);
    }

    .info {
      text-align: center;
      margin-bottom: 2rem;
      font-size: 1.1rem;
      color: #d6c3ff;
      line-height: 1.8rem;
    }

    .info span {
      color: #fff;
      font-weight: 600;
      text-shadow: 0 0 10px rgba(179, 136, 255, 0.6);
    }

    /* BOTÓN VOLVER */
    .btn-back {
      display: inline-block;
      margin-bottom: 2rem;
      padding: 0.7rem 1.5rem;
      background: linear-gradient(135deg, #7b2ff7, #f107a3);
      color: white;
      text-decoration: none;
      border-radius: 12px;
      transition: all 0.25s ease;
      font-weight: 500;
      box-shadow: 0 0 15px rgba(179, 136, 255, 0.45);
    }

    .btn-back:hover {
      transform: scale(1.05) translateY(-2px);
      box-shadow: 0 0 25px rgba(179, 136, 255, 0.8);
    }

    /* TABLA */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 0 20px rgba(179, 136, 255, 0.15);
    }

    thead {
      background: rgba(179, 136, 255, 0.15);
      backdrop-filter: blur(8px);
    }

    th {
      padding: 1rem;
      color: #d9c7ff;
      text-shadow: 0 0 10px rgba(179, 136, 255, 0.4);
      font-size: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    td {
      padding: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      text-align: center;
      font-size: 0.95rem;
    }

    tr:hover {
      background: rgba(179, 136, 255, 0.08);
      transition: 0.2s ease;
    }

    /* IMÁGENES */
    .prod-img {
      width: 70px;
      height: 70px;
      object-fit: contain;
      border-radius: 10px;
      background: rgba(255,255,255,0.05);
      padding: 6px;
      box-shadow: 0 0 12px rgba(179, 136, 255, 0.45);
    }

    #dark-toggle {
      position: fixed;
      top: 20px;
      right: 20px;
      background: transparent;
      border: none;
      color: white;
      font-size: 28px;
      cursor: pointer;
    }
  </style>
</head>

<body>

  <button id="dark-toggle" class="dark-btn">🌙</button>

  <div class="container">

    <h1>Venta #<%= venta.id %></h1>

    <div class="info">
      <% 
        const f = new Date(venta.fecha);
        const fechaEsp = f.toLocaleString("es-AR", {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric",
          hour: "2-digit",
          minute: "2-digit"
        });
      %>

      <p><span>Fecha:</span> <%= fechaEsp %> hs</p>
      <p><span>Total:</span> $<%= venta.total %></p>
    </div>

    <a href="/admin/ventas" class="btn-back">⟵ Volver</a>

    <h2 style="color:#b388ff; margin-top: 2rem; margin-bottom:1rem; text-shadow:0 0 8px rgba(179,136,255,0.5);">
      Productos vendidos
    </h2>

    <table>
      <thead>
        <tr>
          <th>Imagen</th>
          <th>Producto</th>
          <th>Cantidad</th>
          <th>Precio Unitario</th>
        </tr>
      </thead>
      <tbody>
        <% productos.forEach(p => { %>
        <tr>
          <td>
            <img class="prod-img" src="/assets/img/<%= p.img %>" alt="<%= p.nombre %>">
          </td>
          <td><%= p.nombre %></td>
          <td><%= p.cantidad %></td>
          <td>$<%= p.precio_unitario %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>

  </div>

  <script src="/admin_darkmode.js"></script>
</body>
</html>
